# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# The Slack user ID of the person this agent acts on behalf of
AGENT_OWNER_SLACK_ID=U12345678

# The Slack channel ID for the review queue (private channel)
REVIEW_CHANNEL_ID=C12345678

# Claude — pick ONE:
# Option 1: AWS Bedrock (uses AWS SSO credentials, no API key needed)
AWS_REGION=us-east-1
MODEL_ID=global.anthropic.claude-opus-4-6-v1
# Option 2: Anthropic API directly (set this and it will be used instead)
# ANTHROPIC_API_KEY=sk-ant-your-key

# Google Docs (for request tracking)
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
TRACKING_DOC_ID=your-google-doc-id

# GitHub (for codebase RAG)
GITHUB_TOKEN=ghp_your-token

# Digest schedule (cron expression, default: every Friday 5pm)
DIGEST_CRON=0 17 * * 5
